---
// Hero section with animated gradient name, photo, and call-to-action buttons
---

<section id="inicio" class="relative min-h-[calc(100vh-64px)] flex items-center mt-10 pb-20 overflow-hidden">
  <!-- Tech grid background -->
  <div class="tech-grid absolute inset-0 pointer-events-none"></div>
   
  <!-- Particles -->
  <div class="particles absolute inset-0 pointer-events-none">
    {/* These will be generated by JS */}
  </div>
   
  <!-- Auroras/Blur gradients -->
  <div class="absolute inset-0 -z-10">
    <div class="absolute inset-0 bg-linear-to-br from-[var(--color-accent-1)]/5 via-transparent to-[var(--color-accent-3)]/5 blur-3xl"></div>
    <div class="absolute inset-0 bg-linear-to-tr from-[var(--color-accent-2)]/10 via-transparent to-[var(--color-accent-1)]/10 blur-[50px]"></div>
  </div>
   
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full flex flex-col lg:flex-row items-center lg:items-start gap-12 lg:gap-0">
    <!-- Text content -->
    <div class="w-full lg:w-1/2 pr-0 lg:pr-12 space-y-6 text-center lg:text-left pt-17 ">
      <div class="space-y-2">
        <p class="text-lg text-white/50 font-medium tracking-wide">Hola, soy</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold gradient-text animated-gradient leading-tight">
          Vega Nicolás Alexander
        </h1>
        <p class="text-xl text-white/90 font-semibold mt-2">
          Backend Developer especializado en .NET y Arquitectura de Software
        </p>
        <p class="text-lg text-white/60 leading-relaxed max-w-xl ">
          Construyo APIs REST, aplicaciones escalables y soluciones enfocadas en buenas prácticas de desarrollo utilizando el ecosistema .NET.
        </p>
      </div>
       
      <div class="flex flex-wrap gap-4 mt-8 justify-center lg:justify-start">
        <a href="#proyectos" class="btn-primary flex items-center gap-2">
          Ver proyectos
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
         
        <a href="#contacto" class="btn-outline flex items-center gap-2">
          Contactarme
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
        </a>
         
        <a href="/Nicolás Alexander Vega.pdf" download="Nicolas_Vega_CV.pdf" target="_blank" rel="noopener noreferrer" class="btn-outline flex items-center gap-2">
          Descargar CV
          <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
        </a>
      </div>
    </div>
       
    <!-- Photo container (Interactive Backend Terminal Hologram) -->
    <div class="w-full lg:w-1/2 flex items-center justify-center md:mt-5 lg:pl-8">
      <div class=" mt-16 relative w-full max-w-sm h-100 border-animated rounded-2xl overflow-hidden hover-glow transition-all duration-500 float bg-[var(--color-bg-secondary)]/30 backdrop-blur-md flex flex-col justify-between p-6 border border-white/10 shadow-[0_8px_32px_rgba(0,0,0,0.5)]">
        <!-- Glow effects -->
        <div class="absolute top-0 right-0 w-24 h-24 bg-[var(--color-accent-1)]/10 rounded-full blur-2xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-24 h-24 bg-[var(--color-accent-2)]/10 rounded-full blur-2xl pointer-events-none"></div>
        
        <!-- Terminal Header -->
        <div class="flex items-center justify-between pb-3 border-b border-white/10 select-none">
          <div class="flex space-x-2">
            <div class="w-3 h-3 rounded-full bg-red-500/50"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500/50"></div>
            <div class="w-3 h-3 rounded-full bg-green-500/50"></div>
          </div>
          <span class="text-xs font-mono text-white/40">developer.json</span>
        </div>

        <!-- Terminal Body -->
        <div class="flex-1 flex flex-col justify-center space-y-4 font-mono text-sm mt-4">
          <div class="space-y-1">
            <p class="text-white/30 text-xs">// Perfil Profesional</p>
            <p class="text-white"><span class="text-[var(--color-accent-2)]">const</span> dev = &#123;</p>
            <p class="pl-4 text-white/95">name: <span class="text-[var(--color-accent-3)]">"N. Alexander Vega"</span>,</p>
            <p class="pl-4 text-white/95">role: <span class="text-[var(--color-accent-3)]">"Backend Developer"</span>,</p>
            <p class="pl-4 text-white/95">stack: [<span class="text-[var(--color-accent-1)]">"C#"</span>, <span class="text-[var(--color-accent-1)]">".NET Core"</span>],</p>
            <p class="pl-4 text-white/95">status: <span class="text-green-400">"Activo para Trabajo Remoto"</span>,</p>
            <p class="pl-4 text-white/95">age: <span class="text-[var(--color-accent-2)]">19</span></p>
            <p class="text-white">&#125;;</p>
          </div>

          <!-- Pulsing Microchip/CPU visual -->
          <div class="flex items-center justify-center pt-2">
            <div class="relative w-20 h-20 rounded-2xl bg-gradient-to-br from-[var(--color-accent-1)]/10 to-[var(--color-accent-3)]/10 border border-white/10 flex items-center justify-center overflow-hidden group select-none shadow-[0_0_15px_rgba(10,132,255,0.15)]">
              <div class="absolute inset-0 bg-gradient-to-tr from-[var(--color-accent-1)]/20 to-transparent animate-pulse"></div>
              <svg class="h-10 w-10 text-[var(--color-accent-2)] animate-pulse" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z" />
              </svg>
            </div>
          </div>
        </div>

        <!-- Terminal Footer -->
        <div class="pt-3 border-t border-white/10 flex items-center justify-between text-[10px] font-mono text-white/30 select-none">
          <span>LOC: 256</span>
          <span class="text-green-400/80 flex items-center gap-1.5">
            <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-ping"></span>
            CONNECTED_TO_NET_ENGINE
          </span>
        </div>
      </div>
    </div>
  </div>
</section>



<script >
  // Generate floating particles
  function createParticles() {
    const particlesContainer = document.querySelector('.particles');
    if (!particlesContainer) return;
    const count = 24;
    for (let i = 0; i < count; i++) {
      const p = document.createElement('div');
      p.className = 'particle';
      const size = Math.random() * 5 + 1.5;
      p.style.width  = `${size}px`;
      p.style.height = `${size}px`;
      p.style.left   = `${Math.random() * 100}%`;
      p.style.top    = `${Math.random() * 100}%`;
      p.style.setProperty('--dur',   `${Math.random() * 14 + 10}s`);
      p.style.setProperty('--delay', `${Math.random() * 8}s`);
      particlesContainer.appendChild(p);
    }
  }
   
  // Initialize particles when DOM is loaded
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', createParticles);
  } else {
    createParticles();
  }
   
  // Add floating effect to photo
  document.addEventListener('DOMContentLoaded', () => {
    const photoContainer = document.querySelector('.border-animated');
    if (photoContainer) {
      photoContainer.classList.add('float');
    }
  });
</script>