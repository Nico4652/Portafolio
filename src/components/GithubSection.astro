---
// GitHub section showing user stats and repositories
---

<section id="github" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-12">
      <!-- Header -->
      <div class="text-center">
        <h2 class="text-3xl font-bold text-center gradient-text animated-gradient">
          GitHub
        </h2>
        <p class="mt-4 text-lg text-white/60 max-w-2xl mx-auto">
          Explora mi código y proyectos en GitHub
        </p>
      </div>
      
      <!-- GitHub stats -->
      <div class="glass-panel hover-glow transition-all duration-500">
        <div class="p-8">
          <div class="flex items-center justify-between space-x-6">
            <!-- Avatar and username -->
            <div class="shrink-0">
              <div class="w-16 h-16 border-animated rounded-full overflow-hidden hover-glow">
                <img 
                  src="https://avatars.githubusercontent.com/u/Nico4652?v=4" 
                  alt="Avatar de Nico4652 en GitHub" 
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </div>
            </div>
            
            <!-- User info -->
            <div class="flex-1 space-y-2">
              <div class="flex items-baseline space-x-4">
                <h2 class="text-2xl font-bold gradient-text animated-gradient">
                  Nico4652
                </h2>
                <span class="text-sm text-white/60 max-sm:hidden">
                  <a href="https://github.com/Nico4652" target="_blank" rel="noopener noreferrer" class="hover:text-accent-1">
                    github.com/Nico4652
                  </a>
                </span>
              </div>
              <p class="text-white/60">
                Desarrollador Backend especializado en .NET y Arquitectura de Software
              </p>
            </div>
            
            <!-- Stats -->
            <div class="text-right space-y-2">
              <div class="flex items-center space-x-3" title="Repositorios públicos">
                <div class="w-8 h-8 bg-accent-1/20 rounded-xl flex items-center justify-center">
                  <svg class="size-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <path d="M11.245 4.174C11.4765 3.50808 11.5922 3.17513 11.7634 3.08285C11.9115 3.00298 12.0898 3.00298 12.238 3.08285C12.4091 3.17513 12.5248 3.50808 12.7563 4.174L14.2866 8.57639C14.3525 8.76592 14.3854 8.86068 14.4448 8.93125C14.4972 8.99359 14.5641 9.04218 14.6396 9.07278C14.725 9.10743 14.8253 9.10947 15.0259 9.11356L19.6857 9.20852C20.3906 9.22288 20.743 9.23007 20.8837 9.36432C21.0054 9.48051 21.0605 9.65014 21.0303 9.81569C20.9955 10.007 20.7146 10.2199 20.1528 10.6459L16.4387 13.4616C16.2788 13.5829 16.1989 13.6435 16.1501 13.7217C16.107 13.7909 16.0815 13.8695 16.0757 13.9507C16.0692 14.0427 16.0982 14.1387 16.1563 14.3308L17.506 18.7919C17.7101 19.4667 17.8122 19.8041 17.728 19.9793C17.6551 20.131 17.5108 20.2358 17.344 20.2583C17.1513 20.2842 16.862 20.0829 16.2833 19.6802L12.4576 17.0181C12.2929 16.9035 12.2106 16.8462 12.1211 16.8239C12.042 16.8043 11.9593 16.8043 11.8803 16.8239C11.7908 16.8462 11.7084 16.9035 11.5437 17.0181L7.71805 19.6802C7.13937 20.0829 6.85003 20.2842 6.65733 20.2583C6.49056 20.2358 6.34626 20.131 6.27337 19.9793C6.18915 19.8041 6.29123 19.4667 6.49538 18.7919L7.84503 14.3308C7.90313 14.1387 7.93218 14.0427 7.92564 13.9507C7.91986 13.8695 7.89432 13.7909 7.85123 13.7217C7.80246 13.6435 7.72251 13.5829 7.56262 13.4616L3.84858 10.6459C3.28678 10.2199 3.00588 10.007 2.97101 9.81569C2.94082 9.65014 2.99594 9.48051 3.11767 9.36432C3.25831 9.23007 3.61074 9.22289 4.31559 9.20852L8.9754 9.11356C9.176 9.10947 9.27631 9.10743 9.36177 9.07278C9.43726 9.04218 9.50414 8.99359 9.55657 8.93125C9.61593 8.86068 9.64887 8.76592 9.71475 8.57639L11.245 4.174Z" stroke="#0a84ff" stroke-width="1.464" stroke-linecap="round" stroke-linejoin="round"></path> </g></svg>
                </div>
                <span class="font-medium" id="repo-count">-</span>
              </div>
              <div class="flex items-center space-x-3" title="Miembro de GitHub desde (Año)">
                <div class="w-8 h-8 bg-accent-2/20 rounded-xl flex items-center justify-center">
                  <svg class="h-5 w-5 text-accent-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <span class="font-medium" id="github-joined-year">-</span>
              </div>
              <div class="flex items-center space-x-3" title="Seguidores en GitHub">
                <div class="w-8 h-8 bg-accent-3/20 rounded-xl flex items-center justify-center">
                  <svg class="h-5 w-5 text-accent-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                </div>
                <span class="font-medium" id="follower-count">-</span>
              </div>
            </div>
          </div>
          
          <!-- Action buttons -->
          <div class="mt-6 flex space-x-4">
            <a 
              href="https://github.com/Nico4652" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex-1 btn-primary hover:scale-[1.02] hover:shadow-[0_0_20px_rgba(10,132,255,0.4)] transition-all duration-300 flex items-center justify-center gap-2"
            >
              GitHub
              <svg class="h-5 w-5 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.942.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
                </svg>
            </a>
            
            <a 
              href="https://github.com/Nico4652?tab=repositories" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex-1 btn-outline hover:text-accent-1 hover:shadow-[0_0_15px_rgba(10,132,255,0.3)] transition-all duration-300 flex items-center justify-center gap-2"
            >
              repositorios
              <svg fill="#ffffff" width="20px" height="20px" viewBox="0 0 32 32" id="icon" xmlns="http://www.w3.org/2000/svg" stroke="#ffffff" stroke-width="0.00032"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><defs><style>.cls-1{fill:none;}</style></defs><title>data-base</title><path d="M24,3H8A2,2,0,0,0,6,5V27a2,2,0,0,0,2,2H24a2,2,0,0,0,2-2V5A2,2,0,0,0,24,3Zm0,2v6H8V5ZM8,19V13H24v6Zm0,8V21H24v6Z"></path><circle cx="11" cy="8" r="1"></circle><circle cx="11" cy="16" r="1"></circle><circle cx="11" cy="24" r="1"></circle><rect id="_Transparent_Rectangle_" data-name="&lt;Transparent Rectangle&gt;" class="cls-1" width="32" height="32"></rect></g></svg>
            </a>
          </div>
        </div>
      </div>
      
      <!-- Recent activity placeholder -->
      <div class="glass-panel hover-glow transition-all duration-500">
        <div class="p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-lg gradient-text animated-gradient">
              Actividad reciente
            </h3>
            <a 
              href="https://github.com/Nico4652" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="text-sm text-accent-1 hover:text-accent-2 transition-colors duration-200"
            >
              Ver toda la actividad →
            </a>
          </div>
          
          <!-- Activity items would be populated by GitHub API -->
          <div class="space-y-4" id="github-activity">
            <div class="text-center py-6 text-white/50">
              Cargando actividad de GitHub...
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>




<script>
  // Fetch GitHub user data and activity
  async function fetchGitHubData() {
    try {
      // Fetch user data
      const userResponse = await fetch('https://api.github.com/users/Nico4652');
      if (!userResponse.ok) throw new Error('Failed to fetch user data');
      const userData = await userResponse.json();
      
      // Update user stats
      document.getElementById('repo-count').textContent = userData.public_repos?.toLocaleString() || '0';
      
      // Calculate and display member since year
      const joinYear = userData.created_at ? new Date(userData.created_at).getFullYear() : '2023';
      document.getElementById('github-joined-year').textContent = joinYear.toString();
      
      document.getElementById('follower-count').textContent = userData.followers?.toLocaleString() || '0';
      
      // Fetch recent activity (events)
      const activityResponse = await fetch('https://api.github.com/users/Nico4652/events/public', {
        headers: {
          'Accept': 'application/vnd.github.v3+json'
        }
      });
      if (!activityResponse.ok) throw new Error('Failed to fetch activity');
      const activityData = await activityResponse.json();
      
      // Display recent activity
      const activityContainer = document.getElementById('github-activity');
      if (activityData.length > 0) {
        activityContainer.innerHTML = '';
        
        // Show up to 5 recent events
        activityData.slice(0, 5).forEach(event => {
          const eventItem = document.createElement('div');
          eventItem.className = 'flex items-start space-x-3 p-4 bg-white/5 rounded-hover';
          
          // Event type icon
          const eventIcon = document.createElement('div');
          eventIcon.className = 'flex-shrink-0 w-8 h-8 bg-accent-1/20 rounded-xl flex items-center justify-center';
          
          let iconSvg = '';
          switch(event.type) {
            case 'PushEvent':
              iconSvg = '<svg class="h-5 w-5 text-accent-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3M6 6h9a2 2 0 012 2v9a2 2 0 01-2 2H6a2 2 0 01-2-2V8a2 2 0 012-2z"/></svg>';
              break;
            case 'PullRequestEvent':
              iconSvg = '<svg class="h-5 w-5 text-accent-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>';
              break;
            case 'IssuesEvent':
              iconSvg = '<svg class="h-5 w-5 text-accent-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c4 0 6.364 2.574 6.364 5.636v3a2 2 0 01-2 2H8a2 2 0 01-2-2v-3C5.636 10.574 8 8 12 8z"/></svg>';
              break;
            default:
              iconSvg = '<svg class="h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c4 0 6.364 2.574 6.364 5.636v3a2 2 0 01-2 2H8a2 2 0 01-2-2v-3C5.636 10.574 8 8 12 8z"/></svg>';
          }
          
          eventIcon.innerHTML = iconSvg;
          
          // Event description
          const eventDesc = document.createElement('div');
          eventDesc.className = 'flex-1';
          
          let description = '';
          switch(event.type) {
            case 'PushEvent':
              const repoName = event.repo.name.split('/')[1] || event.repo.name;
              const commits = event.payload.commits || [];
              const commitsCount = event.payload.size || commits.length || 0;
              const refName = event.payload.ref ? event.payload.ref.replace('refs/heads/', '') : '';
              
              if (commitsCount > 0) {
                const lastCommitMessage = commits[0].message || '';
                const commitDetails = lastCommitMessage ? `: "${lastCommitMessage}"` : '';
                description = `Actualizado ${repoName} con ${commitsCount} commit${commitsCount !== 1 ? 's' : ''}${commitDetails}`;
              } else if (refName) {
                description = `Push a la rama "${refName}" en ${repoName}`;
              } else {
                description = `Actualizado ${repoName}`;
              }
              break;
            case 'PullRequestEvent':
              const prRepo = event.repo.name.split('/')[1] || event.repo.name;
              description = `Solicitud de extracción #${event.payload.pull_request.number} en ${prRepo}`;
              break;
            case 'IssuesEvent':
              const issueRepo = event.repo.name.split('/')[1] || event.repo.name;
              description = `Issue #${event.payload.issue.number} ${event.payload.action} en ${issueRepo}`;
              break;
            default:
              const defaultRepo = event.repo.name.split('/')[1] || event.repo.name;
              description = `${event.type.replace('Event', '')} en ${defaultRepo}`;
          }
          
          eventDesc.innerHTML = `
            <div class="font-medium text-white">${description}</div>
            <div class="text-xs text-white/50">${new Date(event.created_at).toLocaleDateString()} • ${new Date(event.created_at).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</div>
          `;
          
          eventItem.appendChild(eventIcon);
          eventItem.appendChild(eventDesc);
          activityContainer.appendChild(eventItem);
        });
      } else {
        activityContainer.innerHTML = '<div class="text-center py-6 text-white/50">No hay actividad reciente</div>';
      }
      
    } catch (error) {
      console.error('Error fetching GitHub data:', error);
      document.getElementById('repo-count').textContent = 'Error';
      document.getElementById('github-joined-year').textContent = 'Error';
      document.getElementById('follower-count').textContent = 'Error';
      document.getElementById('github-activity').innerHTML = '<div class="text-center py-6 text-white/50">Error al cargar datos de GitHub</div>';
    }
  }
  
  // Fetch data when component loads
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', fetchGitHubData);
  } else {
    fetchGitHubData();
  }
  
  // Refresh data every 5 minutes
  setInterval(fetchGitHubData, 5 * 60 * 1000);
</script>