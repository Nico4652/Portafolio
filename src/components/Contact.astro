---
// Contact section with form and contact information
---

<section id="contacto" class="py-24 relative overflow-hidden">
  <!-- Glowing Background Elements -->
  <div class="absolute top-1/4 right-0 w-96 h-96 bg-accent-1/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-1/4 left-0 w-96 h-96 bg-accent-2/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="space-y-16">
      <!-- Header -->
      <div class="text-center space-y-4 max-w-3xl mx-auto">
        <h2 class="text-4xl font-extrabold tracking-tight gradient-text animated-gradient">
          Contacto
        </h2>
        <p class="text-lg text-white/60">
          ¿Tienes un proyecto en mente o buscas incorporar un desarrollador Backend .NET a tu equipo? 
          Hablemos. Completa el formulario o escríbeme directamente por cualquiera de estos medios.
        </p>
      </div>
      
      <!-- Contact content -->
      <div class="grid gap-12 lg:grid-cols-12 items-start">
        <!-- Contact form -->
        <div class="lg:col-span-7 glass-panel rounded-3xl p-8 lg:p-10 border border-white/10 shadow-2xl relative overflow-hidden group">
          <!-- Subtle top gradient strip -->
          <div class="absolute top-0 inset-x-0 h-[2px] bg-gradient-to-r from-accent-1 via-accent-2 to-accent-3"></div>
          
          <h3 class="text-2xl font-bold text-white mb-8 flex items-center gap-3">
            <span class="w-2.5 h-2.5 rounded-full bg-accent-1 animate-pulse"></span>
            Enviar un mensaje directo
          </h3>
          
          <form id="contactForm" class="space-y-6">
            <!-- FormSubmit options -->
            <input type="hidden" name="_captcha" value="false">
            <input type="hidden" name="_template" value="table">
            
            <div class="grid gap-6 sm:grid-cols-2">
              <div class="space-y-2">
                <label for="contactName" class="block text-sm font-medium text-white/80">
                  Nombre completo
                </label>
                <input 
                  type="text" 
                  id="contactName" 
                  name="name" 
                  required
                  class="w-full px-4 py-3.5 bg-white/5 border border-white/10 rounded-xl focus:border-accent-2 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-accent-2/20 text-white placeholder-white/30 transition-all duration-300"
                  placeholder="Ej. Juan Pérez"
                />
              </div>
              
              <div class="space-y-2">
                <label for="contactEmail" class="block text-sm font-medium text-white/80">
                  Dirección de email
                </label>
                <input 
                  type="email" 
                  id="contactEmail" 
                  name="email" 
                  required
                  class="w-full px-4 py-3.5 bg-white/5 border border-white/10 rounded-xl focus:border-accent-2 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-accent-2/20 text-white placeholder-white/30 transition-all duration-300"
                  placeholder="ejemplo@correo.com"
                />
              </div>
            </div>
            
            <div class="space-y-2">
              <label for="contactMessage" class="block text-sm font-medium text-white/80">
                Tu mensaje
              </label>
              <textarea 
                id="contactMessage" 
                name="message" 
                rows="5" 
                required
                class="w-full px-4 py-3.5 bg-white/5 border border-white/10 rounded-xl focus:border-accent-2 focus:bg-white/10 focus:outline-none focus:ring-2 focus:ring-accent-2/20 text-white placeholder-white/30 transition-all duration-300 resize-none"
                placeholder="Cuéntame sobre tu proyecto, objetivos o la propuesta laboral..."
              />
            </div>
            
            <button 
              type="submit" 
              class="w-full btn-primary py-4 rounded-xl hover:scale-[1.01] transition-all duration-300 flex items-center justify-center gap-3 text-base font-semibold cursor-pointer shadow-lg shadow-accent-1/20"
            >
              <span>Enviar Mensaje</span>
              <svg class="h-5 w-5 transform group-hover:translate-x-1 transition-transform duration-300" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
            
            <div id="formStatus" class="mt-6 text-sm text-center hidden font-medium transition-all duration-300"></div>
          </form>
        </div>
        
        <!-- Contact info -->
        <div class="lg:col-span-5 space-y-8">
          <!-- Information Card -->
          <div class="glass-panel rounded-3xl p-8 border border-white/10 shadow-2xl relative overflow-hidden">
            <div class="absolute top-0 inset-x-0 h-0.5 bg-linear-to-r from-accent-2 to-accent-3"></div>
            
            <h3 class="text-2xl font-bold text-white mb-8">
              Canales de Comunicación
            </h3>
            
            <div class="space-y-6">
              <!-- Email -->
              <a href="mailto:nvega6511@gmail.com" class="flex items-center space-x-4 p-3 rounded-2xl hover:bg-white/5 border border-transparent hover:border-white/5 transition-all duration-300 group">
                <div class="w-12 h-12 bg-accent-1/10 group-hover:bg-accent-1/25 rounded-xl flex items-center justify-center border border-accent-1/20 transition-all duration-300">
                  <svg class="h-6 w-6 text-accent-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <h4 class="text-xs font-semibold text-white/50 uppercase tracking-widest font-mono">Email Principal</h4>
                  <p class="text-base text-white/85 mt-0.5 truncate font-medium group-hover:text-accent-1 transition-colors">
                    nvega6511@gmail.com
                  </p>
                </div>
              </a>
              
              <!-- LinkedIn -->
              <a href="https://www.linkedin.com/in/nicolas-vega-91a42a412" target="_blank" rel="noopener noreferrer" class="flex items-center space-x-4 p-3 rounded-2xl hover:bg-white/5 border border-transparent hover:border-white/5 transition-all duration-300 group">
                <div class="w-12 h-12 bg-accent-2/10 group-hover:bg-accent-2/25 rounded-xl flex items-center justify-center border border-accent-2/20 transition-all duration-300">
                  <svg class="h-6 w-6 text-accent-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 11a3 3 0 100-6 3 3 0 000 6zm1 8H6a2 2 0 01-2-2V9a2 2 0 012-2h2a2 2 0 012 2v9a2 2 0 01-2 2zm6.5-6.5a2 2 0 100-4 2 2 0 000 4zm0 9h5a2 2 0 002-2v-3a2 2 0 00-2-2h-2v3z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <h4 class="text-xs font-semibold text-white/50 uppercase tracking-widest font-mono">LinkedIn</h4>
                  <p class="text-base text-white/85 mt-0.5 truncate font-medium group-hover:text-accent-2 transition-colors">
                    linkedin.com/in/nicolasvega
                  </p>
                </div>
              </a>
              
              <!-- GitHub -->
              <a href="https://github.com/Nico4652" target="_blank" rel="noopener noreferrer" class="flex items-center space-x-4 p-3 rounded-2xl hover:bg-white/5 border border-transparent hover:border-white/5 transition-all duration-300 group">
                <div class="w-12 h-12 bg-accent-3/10 group-hover:bg-accent-3/25 rounded-xl flex items-center justify-center border border-accent-3/20 transition-all duration-300">
                  <svg class="h-6 w-6 text-accent-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.48.0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.577.688.479C19.138 20.162 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
                  </svg>
                </div>
                <div class="min-w-0 flex-1">
                  <h4 class="text-xs font-semibold text-white/50 uppercase tracking-widest font-mono">GitHub</h4>
                  <p class="text-base text-white/85 mt-0.5 truncate font-medium group-hover:text-accent-3 transition-colors">
                    github.com/Nico4652
                  </p>
                </div>
              </a>
            </div>
          </div>

          <!-- Quick stats / Meta info -->
          <div class="glass-panel rounded-3xl p-6 border border-white/10 shadow-2xl relative overflow-hidden flex items-center justify-between">
            <div class="space-y-1">
              <span class="text-xs font-mono text-white/40 tracking-wider">Ubicación</span>
              <p class="text-sm font-semibold text-white/80">Clorinda, Argentina</p>
            </div>
            <div class="w-px h-10 bg-white/10"></div>
            <div class="space-y-1 text-right">
              <span class="text-xs font-mono text-white/40 tracking-wider">Disponibilidad</span>
              <p class="text-sm font-semibold text-accent-2">Remoto / Full-time</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Toast Container for modern notifications -->
  <div id="toast-container" class="fixed bottom-6 right-6 z-50 flex flex-col gap-3 pointer-events-none max-w-sm w-full px-4 sm:px-0"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm');
    
    // Toast helper function
    function showToast(type: 'success' | 'error', title: string, message: string) {
      const container = document.getElementById('toast-container');
      if (!container) return;

      const toast = document.createElement('div');
      toast.className = `pointer-events-auto relative flex w-full overflow-hidden rounded-2xl border bg-slate-950/90 backdrop-blur-xl shadow-2xl transition-all duration-500 ease-out translate-x-full opacity-0`;
      
      if (type === 'success') {
        toast.classList.add('border-emerald-500/30');
      } else {
        toast.classList.add('border-rose-500/30');
      }

      const iconSvg = type === 'success' 
        ? `<svg class="h-6 w-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
           </svg>`
        : `<svg class="h-6 w-6 text-rose-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
           </svg>`;

      const accentColor = type === 'success' ? 'bg-emerald-500' : 'bg-rose-500';

      toast.innerHTML = `
        <div class="w-1.5 ${accentColor}"></div>
        <div class="flex-1 p-4 pr-3">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 mt-0.5">
              ${iconSvg}
            </div>
            <div class="flex-1 space-y-1">
              <h4 class="text-sm font-bold text-white">${title}</h4>
              <p class="text-xs text-white/70 leading-relaxed">${message}</p>
            </div>
            <button class="text-white/40 hover:text-white/80 transition-colors flex-shrink-0 close-toast-btn">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
        <div class="absolute bottom-0 left-0 h-[3px] ${accentColor}/50 transition-all duration-[4000ms] ease-linear w-full" id="progress-bar"></div>
      `;

      // Setup close button event
      const closeBtn = toast.querySelector('.close-toast-btn');
      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          toast.classList.add('translate-x-full', 'opacity-0');
          setTimeout(() => toast.remove(), 400);
        });
      }

      container.appendChild(toast);

      // Trigger animation
      setTimeout(() => {
        toast.classList.remove('translate-x-full', 'opacity-0');
      }, 10);

      // Animate progress bar
      const progressBar = toast.querySelector('#progress-bar') as HTMLElement;
      if (progressBar) {
        setTimeout(() => {
          progressBar.style.width = '0%';
        }, 50);
      }

      // Auto remove toast
      setTimeout(() => {
        if (toast.parentNode) {
          toast.classList.add('translate-x-full', 'opacity-0');
          setTimeout(() => toast.remove(), 500);
        }
      }, 4000);
    }

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Show loading state
        const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const submitText = submitButton.querySelector('span');
        const originalButtonText = submitText ? submitText.textContent : 'Enviar Mensaje';
        
        submitButton.disabled = true;
        if (submitText) submitText.textContent = 'Enviando mensaje...';
        
        try {
          const formData = new FormData(form as HTMLFormElement);
          const data = Object.fromEntries(formData);
          
          // FormSubmit AJAX endpoint.
          // Including the 'name' field allows FormSubmit to set the sender's name in your inbox.
          const response = await fetch('https://formsubmit.co/ajax/nvega6511@gmail.com', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify({
              name: data.name, // FormSubmit uses this key to set the email From/Sender display name in Gmail
              "📧 Correo Electrónico": data.email,
              "💬 Mensaje Recibido": data.message,
              _subject: data.name,
              _captcha: "false",
              _template: "box"
            })
          });
          
          const result = await response.json();
          
          if (response.ok && (result.success === "true" || result.success === true)) {
            showToast(
              'success', 
              '¡Mensaje enviado con éxito!', 
              'Gracias por escribir. Te responderé lo antes posible.'
            );
            (form as HTMLFormElement).reset();
          } else {
            throw new Error(result.message || 'FormSubmit returned error status');
          }
        } catch (error) {
          showToast(
            'error', 
            'Error al enviar el mensaje', 
            'Ocurrió un error. Por favor escribe directamente a nvega6511@gmail.com'
          );
          console.error('Submission error:', error);
        } finally {
          submitButton.disabled = false;
          if (submitText) submitText.textContent = originalButtonText;
        }
      });
    }
  });
</script>