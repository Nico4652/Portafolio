---
// Technologies section with interactive cards
---

<section id="tecnologias" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-12">
      <!-- Header -->
      <div class="text-center">
        <h2 class="text-3xl font-bold text-center gradient-text animated-gradient">
          Tecnologías
        </h2>        
        <p class="mt-4 text-lg text-white/60 max-w-2xl mx-auto">
          Dominio de herramientas modernas para desarrollo full-stack, con énfasis en backend y arquitectura de software.
        </p>
      </div>
      
      <!-- Tech Dashboard -->
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {/* Backend */}
        <div class="glass-panel p-6 hover:-translate-y-1.5 hover:bg-white/10 hover:border-white/25 hover:shadow-[0_8px_30px_rgba(10,132,255,0.15)] transition-all duration-300 group cursor-pointer rounded-2xl border border-white/10">
          <div class="flex flex-col space-y-4 max-sm:flex-row max-sm:gap-2.5 max-sm:items-center ">
            <div class="w-12 h-12 bg-accent-1/10 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg fill="#0a84ff" width="30px" height="30px" viewBox="0 0 32 32" id="icon" xmlns="http://www.w3.org/2000/svg" stroke="#0a84ff" stroke-width="0.00032"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><defs><style>.cls-1{fill:none;}</style></defs><title>datastore</title><circle cx="23" cy="23" r="1"></circle><rect x="8" y="22" width="12" height="2"></rect><circle cx="23" cy="9" r="1"></circle><rect x="8" y="8" width="12" height="2"></rect><path d="M26,14a2,2,0,0,0,2-2V6a2,2,0,0,0-2-2H6A2,2,0,0,0,4,6v6a2,2,0,0,0,2,2H8v4H6a2,2,0,0,0-2,2v6a2,2,0,0,0,2,2H26a2,2,0,0,0,2-2V20a2,2,0,0,0-2-2H24V14ZM6,6H26v6H6ZM26,26H6V20H26Zm-4-8H10V14H22Z"></path><rect id="_Transparent_Rectangle_" data-name="&lt;Transparent Rectangle&gt;" class="cls-1" width="32" height="32"></rect></g></svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-white group-hover:text-accent-1 transition-colors">Backend</h3>
              <p class="mt-2 text-sm text-white/60 leading-relaxed font-mono">
                C# <br>
                ASP.NET Core <br>
                Entity Framework <br>
                SQL Server
              </p>
            </div>
          </div>
        </div>
        
        {/* Frontend */}
        <div class="glass-panel p-6 hover:-translate-y-1.5 hover:bg-white/10 hover:border-white/25 hover:shadow-[0_8px_30px_rgba(56,189,248,0.15)] transition-all duration-300 group cursor-pointer rounded-2xl border border-white/10">
          <div class="flex flex-col space-y-4 max-sm:flex-row max-sm:gap-2.5 max-sm:items-center ">
            <div class="w-12 h-12 bg-accent-2/10 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg fill="#38bdf8" version="1.1" id="Capa_1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 31.826 31.826" xml:space="preserve" stroke="#38bdf8" stroke-width="0.00031826"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <g> <g> <polygon points="31.826,29.514 28.676,27.54 28.676,28.877 2.611,28.877 2.611,3.488 3.948,3.488 1.974,0.339 0,3.488 1.336,3.488 1.336,30.151 28.676,30.151 28.676,31.487 "></polygon> <polygon points="3.901,27.729 27.745,27.729 27.745,18.399 25.659,11.335 22.641,9.866 20.169,17.839 16.42,3.405 12.538,13.533 9.643,11.859 8.048,17.014 3.901,15.182 "></polygon> </g> </g> </g></svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-white group-hover:text-accent-2 transition-colors">Frontend</h3>
              <p class="mt-2 text-sm text-white/60 leading-relaxed font-mono">
                React <br>
                Next.js <br>
                TypeScript
              </p>
            </div>
          </div>
        </div>
        
        {/* Mobile */}
        <div class="glass-panel p-6 hover:-translate-y-1.5 hover:bg-white/10 hover:border-white/25 hover:shadow-[0_8px_30px_rgba(96,165,250,0.15)] transition-all duration-300 group cursor-pointer rounded-2xl border border-white/10">
          <div class="flex flex-col space-y-4 max-sm:flex-row max-sm:gap-2.5 max-sm:items-center ">
            <div class="w-12 h-12 bg-accent-3/10 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg width="28px" height="28px" viewBox="0 0 16 16" version="1.1" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" fill="#60a5fa"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <rect width="16" height="16" id="icon-bound" fill="none"></rect> <path d="M11.5,0h-7C3.675,0,3,0.675,3,1.5v13C3,15.325,3.675,16,4.5,16h7c0.825,0,1.5-0.675,1.5-1.5v-13C13,0.675,12.325,0,11.5,0z M8,15c-0.553,0-1-0.447-1-1s0.447-1,1-1s1,0.447,1,1S8.553,15,8,15z M12,12H4V2h8V12z"></path> </g></svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-white group-hover:text-accent-3 transition-colors">Mobile</h3>
              <p class="mt-2 text-sm text-white/60 leading-relaxed font-mono">
                React Native <br>
                Expo
              </p>
            </div>
          </div>
        </div>
        
        {/* Tools */}
        <div class="glass-panel p-6 hover:-translate-y-1.5 hover:bg-white/10 hover:border-white/25 hover:shadow-[0_8px_30px_rgba(255,255,255,0.08)] transition-all duration-300 group cursor-pointer rounded-2xl border border-white/10">
          <div class="flex flex-col space-y-4 max-sm:flex-row max-sm:gap-2.5 max-sm:items-center ">
            <div class="w-12 h-12 bg-white/10 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
              <svg class="h-7 w-7 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h3 class="font-bold text-lg text-white group-hover:text-white transition-colors">Herramientas</h3>
              <p class="mt-2 text-sm text-white/60 leading-relaxed font-mono">
                Git <br>
                GitHub <br>
                Postman
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .glass-panel:hover svg {
    @apply scale-110;
  }
</style>

<script>
  // Add interactive hover effects to tech cards
  document.addEventListener('DOMContentLoaded', () => {
    const techCards = document.querySelectorAll('#tecnologias .glass-panel');
    
    techCards.forEach(card => {
      card.addEventListener('mouseenter', () => {
        // Add subtle glow effect
        card.style.boxShadow = '0 0 20px rgba(10, 132, 255, 0.3)';
      });
      
      card.addEventListener('mouseleave', () => {
        // Remove glow effect
        card.style.boxShadow = '0 8px 32px rgba(0, 0, 0, 0.37)';
      });
      
      // Change icon color based on card
      const icon = card.querySelector('svg');
      if (icon) {
        if (card.querySelector('h3').textContent.includes('Backend')) {
          icon.style.color = 'var(--color-accent-1)';
        } else if (card.querySelector('h3').textContent.includes('Frontend')) {
          icon.style.color = 'var(--color-accent-2)';
        } else if (card.querySelector('h3').textContent.includes('Mobile')) {
          icon.style.color = 'var(--color-accent-3)';
        }
      }
    });
  });
</script>