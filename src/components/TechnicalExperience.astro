---
// Technical experience section with timeline
---

<section id="experiencia-tecnica" class="py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="space-y-12">
      <!-- Header -->
      <div class="text-center">
        <h2 class="text-3xl font-bold text-center gradient-text animated-gradient">
          Experiencia Técnica
        </h2>
        <p class="mt-4 text-lg text-white/60 max-w-2xl mx-auto">
          Desarrollo de proyectos personales enfocados en backend utilizando ASP.NET Core y SQL Server.
          Implementación de APIs REST, Entity Framework, Arquitectura de Software, Validaciones, 
          Modelado de bases de datos y Integración frontend/backend.
        </p>
      </div>
      
      <!-- Timeline -->
      <div class="relative">
        <!-- Timeline line -->
        <div class="absolute inset-x-0 top-0 bottom-0 w-0.5 bg-accent-1/20"></div>
        
        {/* Timeline items */}
        <div class="relative pt-12 pb-20 space-y-12">
          {/* Item 1: Proyecto inicial */}
          
          {/* Item 2: Proyecto intermedio */}
          <div class="relative">
            {/* Timeline dot */}
            <div class="absolute -left-2.5 top-0 flex h-5 w-5 items-center justify-center rounded-full bg-accent-2 shadow-lg">
              <div class="h-2.5 w-2.5 rounded-full bg-white"></div>
            </div>
            
            {/* Timeline content */}
            <div class="ml-8 bg-white/5 rounded-xl p-6 hover-glow transition-all duration-500 relative z-10">
              <div class="flex items-start space-x-4">
                <div class="shrink-0">
                  <div class="w-10 h-10 bg-accent-2/20 rounded-xl flex items-center justify-center">
                    <svg class="h-6 w-6 text-accent-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h3 class="font-bold text-lg gradient-text animated-gradient">Sistema de Gestión para Emprendimiento</h3>
                  <p class="mt-2 text-sm text-white/60">
                    Proyecto completo con arquitectura limpia, incluyendo módulos de productos, ventas, 
                    stock, control de costos y reportes. Integración con frontend React y testing unitario.
                  </p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <span class="bg-accent-1/20 text-accent-1 px-2 py-1 rounded text-xs">Clean Architecture</span>
                    <span class="bg-accent-2/20 text-accent-2 px-2 py-1 rounded text-xs">DTOs</span>
                    <span class="bg-accent-3/20 text-accent-3 px-2 py-1 rounded text-xs">FluentValidation</span>
                    <span class="bg-accent-2/20 text-accent-2 px-2 py-1 rounded text-xs">Entity Framework</span>
                    <span class="bg-accent-3/20 text-accent-3 px-2 py-1 rounded text-xs">SQL Server</span>
                    <span class="bg-accent-1/20 text-accent-1 px-2 py-1 rounded text-xs">MediatR</span>
                    <span class="bg-accent-2/20 text-accent-2 px-2 py-1 rounded text-xs">Behavior</span>
                  
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          {/* Item 3: Proyecto avanzado */}
          <div class="relative">
            {/* Timeline dot */}
            <div class="absolute -left-2.5 top-0 flex h-5 w-5 items-center justify-center rounded-full bg-accent-3 shadow-lg">
              <div class="h-2.5 w-2.5 rounded-full bg-white"></div>
            </div>
            
            {/* Timeline content */}
            <div class="ml-8 bg-white/5 rounded-xl p-6 hover-glow transition-all duration-500 relative z-10">
              <div class="flex items-start space-x-4">
                <div class="shrink-0">
                  <div class="w-10 h-10 bg-accent-3/20 rounded-xl flex items-center justify-center">
                    <svg class="h-6 w-6 text-accent-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h10M11 6h6" />
                    </svg>
                  </div>
                </div>
                <div>
                  <h3 class="font-bold text-lg gradient-text animated-gradient">Sistema de Gestión para Emprendimiento</h3>
                  <p class="mt-2 text-sm text-white/60">
                    Proyecto completo con arquitectura limpia, incluyendo módulos de productos, ventas, 
                    stock, control de costos y reportes. Integración con frontend React y testing unitario.
                  </p>
                  <div class="mt-3 flex flex-wrap gap-2">
                    <span class="bg-accent-1/20 text-accent-1 px-2 py-1 rounded text-xs">Clean Architecture</span>
                    <span class="bg-accent-2/20 text-accent-2 px-2 py-1 rounded text-xs">React</span>
                    <span class="bg-accent-3/20 text-accent-3 px-2 py-1 rounded text-xs">Testing Unitario</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Timeline animations */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  
  .timeline-animate {
    animation: fadeInUp 0.8s ease-out forwards;
  }
</style>

<script>
  // Animate timeline items when they enter viewport
  function animateTimelineItems() {
    const timelineItems = document.querySelectorAll('#experiencia-tecnica .relative > div');
    timelineItems.forEach((item, index) => {
      setTimeout(() => {
        item.classList.add('timeline-animate');
      }, index * 200);
    });
  }
  
  // Intersection Observer for timeline
  const timelineObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateTimelineItems();
        timelineObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  
  // Observe the timeline container
  document.addEventListener('DOMContentLoaded', () => {
    const timelineContainer = document.querySelector('#experiencia-tecnica');
    if (timelineContainer) {
      timelineObserver.observe(timelineContainer);
    }
  });
</script>